@page
@model OnlineShop.Presentation.Pages.Products.MyProductsModel

@{
    ViewData["Title"] = "Мої товари";
}

<h2 class="mb-4">Мої товари</h2>

@if (Model.MyProducts.Any())
{
    <div class="row">
        @foreach (var product in Model.MyProducts)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm border-0">

                    <img src="@product.Image_Url"
                         alt="@product.Title"
                         style="height:200px; object-fit:cover;" />

                    <div class="card-body d-flex flex-column">

                        <h5 class="card-title">@product.Title</h5>

                        <p class="fw-bold text-success">
                            @product.Price грн
                        </p>

                        <a asp-page="/Products/ProductDetail"
                           asp-route-id="@product.Id"
                           class="btn btn-outline-primary mb-2">
                            Детальніше
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <p class="text-muted">У вас немає активних товарів.</p>
}