@page
@model The_cheapest_prices.Pages.MyProductsModel
@{
    ViewData["Title"] = "Мої товари";
}
<h2>Мої товари</h2>

@if (Model.MyProducts?.Any() ?? false)
{
    <div class="row">
        @foreach (var product in Model.MyProducts)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm border-0">
                    <img src="/@product.Image_Url" alt="@product.Title" style="height:200px; object-fit:cover;" />
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@product.Title</h5>
                        <p class="card-text fw-bold text-success">@product.Price грн</p>

                        <form method="post" asp-page-handler="ToggleAvailability" class="mt-auto">
                            <input type="hidden" name="productId" value="@product.Id" />
                            <button type="submit" class="btn btn-warning w-100">
                                Товар закінчився
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <p>У вас немає активних товарів.</p>
}