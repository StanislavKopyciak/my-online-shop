@page
@model The_cheapest_prices.Pages.SearchModel

@{
    ViewData["Title"] = "Результати пошуку";
}

<h2>Результати пошуку для: "@Model.Query"</h2>

@if (Model.Results?.Any() ?? false)
{
    <div class="row">
        @foreach (var product in Model.Results)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm border-0">
                    <img src="/@product.Image_Url" alt="Фото товару" style="height:200px; object-fit:cover;" />
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@product.Title</h5>
                        <p class="card-text fw-bold text-success">@product.Price грн</p>
                        <a href="/ProductDetail?id=@product.Id" class="btn btn-outline-primary mt-auto w-100">Детальніше</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <p>Нічого не знайдено.</p>
}

