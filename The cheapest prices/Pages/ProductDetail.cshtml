@page
@model The_cheapest_prices.Pages.ProductDetailModel
@{
    ViewData["Title"] = "Деталі продукту";
}

<div class="container mt-5">
    @if (Model.Product != null)
    {
        <div class="card mb-4 mx-auto" style="max-width: 700px;">
            <img src="/@Model.Product?.Image_Url" class="card-img-top" alt="@Model.Product?.Title" style="max-height:400px; object-fit: contain;">
            <div class="card-body">
                <h5 class="card-title">ID продавця:@Model.Product?.Seller_Id</h5>
                <h5 class="card-title">@Model.Product?.Title</h5>
                <p class="card-text">@Model.Product?.Description</p>
                <p class="card-text"><strong>Ціна:</strong> @Model.Product?.Price грн</p>
                <p class="card-text"><strong>Наявність:</strong> @(Model.Product?.Available == 1 ? "В наявності" : "Немає в наявності")</p>
                <p class="card-text"><strong>Доставка:</strong> @(Model.Product?.With_Delivery == 1 ? "З доставкою" : "Без доставки")</p>
                <p class="card-text"><strong>Місто:</strong> @Model.Product?.City</p>
                <p class="card-text"><strong>Адреса:</strong> @Model.Product?.Address</p>
                <p class="card-text"><small class="text-muted">Додано: @Model.Product?.Created_At.ToString("dd.MM.yyyy")</small></p>
                <a href="/" class="btn btn-secondary mt-3">Назад до списку</a>

                @if (Model.Product?.Available == 1)
                {
                    <form method="post" asp-page-handler="Buy" class="mt-3">
                        <input type="hidden" name="productId" value="@Model.Product.Id" />
                        <button type="submit" class="btn btn-success w-100" onclick="return confirm('Ви хочете придбати цей товар?');">
                            Придбати
                        </button>
                    </form>
                }
                else
                {
                    <p class="text-danger mt-3 fw-bold">Товар недоступний для покупки</p>
                }
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-danger">Продукт не знайдено.</div>
    }
</div>

